{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            course_id as \"course_id!: Uuid\",\n            title as \"title!\",\n            user_id as \"user_id!: Uuid\",\n            description,\n            is_published as \"is_published!\",\n            lesson_count,\n            total_cards,\n            created_at as \"created_at!\",\n            updated_at\n        FROM course_summary\n        WHERE is_published = true\n            AND (\n                LOWER(title) LIKE $1 \n                OR LOWER(description) LIKE $1\n            )\n        ORDER BY created_at DESC\n        LIMIT $2 OFFSET $3\n        ",
