  "query": "\n            UPDATE course\n            SET \n                title = COALESCE($1, title),\n                description = COALESCE($2, description),\n                updated_at = NOW()\n            WHERE course_id = $3\n            RETURNING \n                course_id,\n                user_id,\n                title,\n                description,\n                is_published,\n                created_at,\n                updated_at\n            ",
