  "query": "\n            UPDATE \"user\"\n            SET \n                username = COALESCE($1, username),\n                email = COALESCE($2, email),\n                updated_at = NOW()\n            WHERE user_id = $3\n            RETURNING \n                user_id,\n                username,\n                email,\n                role as \"role: Role\",\n                created_at,\n                updated_at\n            ",
